-- ============================================================
-- EXECUTE SCRIPT
-- ============================================================
local function ExecuteScript()
    local url = CONFIG.ScriptURL
    if url == "YOUR_SCRIPT_URL_HERE" or url == "" then
        warn("[MozCraft Loader] No script URL configured. Skipping.")
        return
    end
    local ok, err = pcall(function()
        loadstring(game:HttpGet(url, true))()
    end)
    if not ok then
        warn("[MozCraft Loader] Script error: " .. tostring(err))
    end
end

