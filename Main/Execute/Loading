local function PlayEntrance()
    local si  = TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local si2 = TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)

    -- Staggered fade-ins
    task.spawn(function()
        Tween(LogoLabel,  si,  { TextTransparency = 0 })
        task.wait(0.12)
        Tween(GlowLabel,  si,  { TextTransparency = 0.55 })
        task.wait(0.12)
        Tween(SplashLabel, si, { TextTransparency = 0 })
        task.wait(0.12)
        Tween(StageLabel,  si, { TextTransparency = 0 })
        task.wait(0.12)
        Tween(BarBack, si2, { BackgroundTransparency = 0 })
        task.wait(0.08)
        Tween(PctLabel, si, { TextTransparency = 0 })
    end)
end

-- ============================================================
-- PARTICLES
-- ============================================================
local function SpawnParticle()
    local size  = math.random(5, 18)
    local x     = math.random(0, 100) / 100
    local color = RandomFrom(CONFIG.ParticleColors)

    local p = Instance.new("Frame")
    p.Size              = UDim2.new(0, size, 0, size)
    p.Position          = UDim2.new(x, 0, 1.04, 0)
    p.BackgroundColor3  = color
    p.BackgroundTransparency = 0.25
    p.BorderSizePixel   = 0
    p.ZIndex            = 7
    p.Rotation          = math.random(0, 90)
    p.Parent            = ParticleContainer

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0.15, 0)
    corner.Parent = p

    local drift    = (math.random(-25, 25) / 1000)
    local duration = math.random(32, 65) / 10

    Tween(p, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
        Position             = UDim2.new(x + drift, 0, -0.08 - math.random(0, 25) / 100, 0),
        Rotation             = p.Rotation + math.random(-160, 160),
        BackgroundTransparency = 1,
    })

    table.insert(State.particles, p)
    task.delay(duration, function()
        if p and p.Parent then p:Destroy() end
    end)
end

local function StartParticles()
    task.spawn(function()
        while State.running do
            SpawnParticle()
            task.wait(CONFIG.ParticleInterval)
        end
    end)
end

-- ============================================================
-- LOGO ANIMATIONS
-- ============================================================
local function StartLogoAnimations()
    local floatInfo = TweenInfo.new(2.0, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)

    local function floatLoop()
        if not State.running then return end
        TweenWait(LogoLabel, floatInfo, { Position = UDim2.new(0, 0, 0, 7) })
        if not State.running then return end
        TweenWait(LogoLabel, floatInfo, { Position = UDim2.new(0, 0, 0, 0) })
        if State.running then task.spawn(floatLoop) end
    end
    task.spawn(floatLoop)

    local function glowFloat()
        if not State.running then return end
        TweenWait(GlowLabel, floatInfo, { Position = UDim2.new(-0.03, 0, 0, 7) })
        if not State.running then return end
        TweenWait(GlowLabel, floatInfo, { Position = UDim2.new(-0.03, 0, 0, 0) })
        if State.running then task.spawn(glowFloat) end
    end
    task.spawn(glowFloat)

    local pulseInfo = TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
    local function glowPulse()
        if not State.running then return end
        TweenWait(GlowLabel, pulseInfo, { TextTransparency = 0.22 })
        if not State.running then return end
        TweenWait(GlowLabel, pulseInfo, { TextTransparency = 0.75 })
        if State.running then task.spawn(glowPulse) end
    end
    task.spawn(glowPulse)
end

-- ============================================================
-- BACKGROUND SLIDE SYSTEM
-- ============================================================
local function ChangeBackground()
    local nextIdx = (State.currentSlide % #CONFIG.Slides) + 1
    local slide   = CONFIG.Slides[nextIdx]

    State.bgB.Image             = slide.Decal
    State.bgB.ImageTransparency = 1

    local fadeIn  = TweenInfo.new(CONFIG.FadeTime, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    local fadeOut = TweenInfo.new(CONFIG.FadeTime, Enum.EasingStyle.Sine, Enum.EasingDirection.In)

    Tween(State.bgB, fadeIn,  { ImageTransparency = 0.30 })
    TweenWait(State.bgA, fadeOut, { ImageTransparency = 1 })

    -- Swap
    State.bgA.Image             = slide.Decal
    State.bgA.ImageTransparency = 0.30
    State.bgB.ImageTransparency = 1
    State.currentSlide          = nextIdx

    -- Fade title out → update → fade in
    local titleFade = TweenInfo.new(0.35, Enum.EasingStyle.Sine)
    TweenWait(LogoLabel, titleFade, { TextTransparency = 1 })
    TweenWait(GlowLabel, titleFade, { TextTransparency = 1 })

    LogoLabel.Text = slide.Title
    GlowLabel.Text = slide.Title

    if slide.Subtitle then
        SubtitleLabel.Text = slide.Subtitle
        Tween(SubtitleLabel, TweenInfo.new(0.45, Enum.EasingStyle.Sine), { TextTransparency = 0 })
    else
        Tween(SubtitleLabel, TweenInfo.new(0.35, Enum.EasingStyle.Sine), { TextTransparency = 1 })
    end

    local titleShow = TweenInfo.new(0.50, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
    Tween(LogoLabel, titleShow, { TextTransparency = 0 })
    Tween(GlowLabel, titleShow, { TextTransparency = 0.55 })
end

local function StartSlideshow()
    task.spawn(function()
        while State.running do
            task.wait(CONFIG.SlideDuration)
            if State.running then ChangeBackground() end
        end
    end)
end

-- ============================================================
-- SPLASH ROTATION
-- ============================================================
local function StartSplashRotation()
    task.spawn(function()
        while State.running do
            task.wait(CONFIG.SplashInterval)
            if not State.running then break end
            local fi = TweenInfo.new(0.28, Enum.EasingStyle.Sine)
            TweenWait(SplashLabel, fi, { TextTransparency = 1 })
            SplashLabel.Text = RandomFrom(CONFIG.SplashTexts)
            TweenWait(SplashLabel, fi, { TextTransparency = 0 })
        end
    end)
end

-- ============================================================
-- PROGRESS BAR
-- ============================================================
local function UpdateProgress(targetPct)
    local barInfo = TweenInfo.new(0.65, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    Tween(BarFillObj, barInfo, { Size = UDim2.new(targetPct, 0, 1, 0) })

    local startPct = State.progress
    local diff     = targetPct - startPct
    local steps    = 40
    task.spawn(function()
        for i = 1, steps do
            local val = startPct + diff * (i / steps)
            PctLabel.Text = math.floor(val * 100) .. "%"
            task.wait(0.65 / steps)
        end
        PctLabel.Text = math.floor(targetPct * 100) .. "%"
    end)

    State.progress = targetPct
end

