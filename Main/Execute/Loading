-- FINISH — SMOOTH FULL FADE-OUT
-- ============================================================
local function FinishLoading()
    State.running = false

    -- Fade out ambient sound
    if LoadSound then
        Tween(LoadSound, TweenInfo.new(1.0, Enum.EasingStyle.Sine), { Volume = 0 })
        task.delay(1.0, function() if LoadSound and LoadSound.Parent then LoadSound:Stop() end end)
    end

    -- Finish chime
    if FinishSound then FinishSound:Play() end

    -- Complete the bar
    UpdateProgress(1.0)
    StageLabel.Text = "✓  Ready!"
    task.wait(0.7)

    -- ── Full-screen black fade-out ────────────────────────
    --  FadeOverlay sits on top of everything (ZIndex 50).
    --  We fade it from transparent → opaque over FinishFadeTime,
    --  creating a clean cinema-black fade-out effect.
    local fadeInfo = TweenInfo.new(CONFIG.FinishFadeTime, Enum.EasingStyle.Sine, Enum.EasingDirection.In)
    TweenWait(FadeOverlay, fadeInfo, { BackgroundTransparency = 0 })

    -- Hold one beat at full black
    task.wait(0.25)

    -- Fade blur out (it was already mostly covered but clean it up)
    if BlurEffect and BlurEffect.Parent then
        BlurEffect.Size = 0
        BlurEffect:Destroy()
    end

    -- Cleanup everything
    if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
    if LoadSound  and LoadSound.Parent  then LoadSound:Destroy()  end

    -- Run external script
    ExecuteScript()
end

-- ============================================================
-- LOADING SEQUENCER
-- ============================================================
local function StartLoading()
    -- Blur in
    Tween(BlurEffect, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), { Size = 18 })

    -- Fade in the screen
    TweenWait(MainFrame, TweenInfo.new(0.65, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), { BackgroundTransparency = 0 })

    task.wait(0.15)
    SubtitleLabel.TextTransparency = 1

    -- Entrance stagger
    PlayEntrance()
    task.wait(0.5)   -- let entrance settle before loops start

    StartLogoAnimations()
    StartParticles()
    StartSlideshow()
    StartSplashRotation()

    -- Advance stages
    for i, stage in ipairs(CONFIG.Stages) do
        State.currentStage = i
        StageLabel.Text    = stage.label
        UpdateProgress(stage.pct)
        local waitTime = (i < #CONFIG.Stages) and CONFIG.StageInterval or 0.9
        task.wait(waitTime)
    end

    FinishLoading()
end

-- ============================================================
-- MAIN
-- ============================================================
local function Main()
    if not LocalPlayer.Character then
        LocalPlayer.CharacterAdded:Wait()
    end

    SetupSounds()
    CreateUI()
    StartLoading()
end

local ok, err = pcall(Main)
if not ok then
    warn("[MozCraft Loader] Fatal error: " .. tostring(err))
end
