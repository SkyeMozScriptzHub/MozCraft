-- ============================================================
-- UTILITY
-- ============================================================
local function Tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local function TweenWait(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    t.Completed:Wait()
end

local function RandomFrom(t)
    return t[math.random(1, #t)]
end

