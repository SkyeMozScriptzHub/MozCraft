--  CHARACTER ARM SWING
-- ══════════════════════════════════════════════════════════════
local rightShoulder, defaultC0
local swingActive = false

local function setupArm()
    local char    = player.Character or player.CharacterAdded:Wait()
    local human   = char:WaitForChild("Humanoid")
    if human.RigType == Enum.HumanoidRigType.R15 then
        local upper = char:WaitForChild("RightUpperArm",3)
        rightShoulder = upper and upper:FindFirstChild("RightShoulder")
    else
        local torso = char:WaitForChild("Torso",3)
        rightShoulder = torso and torso:FindFirstChild("Right Shoulder")
    end
    if rightShoulder then defaultC0=rightShoulder.C0 end
end
setupArm()

local function smoothTween(joint,goal,dur,style)
    style=style or Enum.EasingStyle.Sine
    TweenService:Create(joint,TweenInfo.new(dur,style,Enum.EasingDirection.Out),{C0=goal}):Play()
end

local function playHandSwing()
    if not rightShoulder or not defaultC0 or swingActive then return end
    swingActive=true
    task.spawn(function()
        smoothTween(rightShoulder,
            defaultC0*CFrame.Angles(math.rad(-20),math.rad(15),math.rad(-8)),0.08,Enum.EasingStyle.Sine)
        task.wait(0.08)
        smoothTween(rightShoulder,
            defaultC0*CFrame.Angles(math.rad(65),math.rad(18),math.rad(10)),0.11,Enum.EasingStyle.Quad)
        task.wait(0.11)
        smoothTween(rightShoulder,defaultC0,0.16,Enum.EasingStyle.Sine)
        task.wait(0.16)
        swingActive=false
    end)
end

