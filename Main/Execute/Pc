-- ══════════════════════════════════════════════════════════════
--  GRID MATH
-- ══════════════════════════════════════════════════════════════
local function snap1(v)   return math.floor(v/SNAP+0.5)*SNAP end
local function snapVec(v) return Vector3.new(snap1(v.X),snap1(v.Y),snap1(v.Z)) end
local function gridKey(pos)
    return math.floor(pos.X/SNAP+0.5)..","..math.floor(pos.Y/SNAP+0.5)..","..math.floor(pos.Z/SNAP+0.5)
end
local function registerBlock(b)
    S.grid[gridKey(b.Position)] = b; table.insert(S.blocks, b)
end
local function unregisterBlock(b)
    S.grid[gridKey(b.Position)] = nil
    for i = #S.blocks,1,-1 do if S.blocks[i]==b then table.remove(S.blocks,i) break end end
end
local function blockAtSnappedPos(p) return S.grid[gridKey(p)] end
local function calcPlacementCenter(r)
    return snapVec(snapVec(r.Position - r.Normal*(SNAP*0.5)) + r.Normal*SNAP)
end

