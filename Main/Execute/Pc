--  BREAK PARTICLES
-- ══════════════════════════════════════════════════════════════
local PARTICLE_COUNT    = 16
local PARTICLE_LIFETIME = 0.65
local PSIZE_MIN         = 0.22
local PSIZE_MAX         = 0.55

local function spawnBreakParticles(blockPart)
    local origin = blockPart.Position
    local texIds = {}
    for _,ch in ipairs(blockPart:GetChildren()) do
        if ch:IsA("Texture") and ch.Texture~="" then table.insert(texIds,ch.Texture) end
    end
    if #texIds==0 then texIds=FACE_TEXTURE_LIST end

    local function rb(a,b) return a+math.random()*(b-a) end

    for _=1,PARTICLE_COUNT do
        local sz    = rb(PSIZE_MIN,PSIZE_MAX)
        local thick = sz*rb(0.25,0.55)
        local p     = Instance.new("Part")
        p.Anchored=false; p.CanCollide=false; p.CanQuery=false
        p.CastShadow=false; p.Material=Enum.Material.SmoothPlastic
        local ax=math.random(1,3)
        if ax==1 then p.Size=Vector3.new(thick,sz,sz)
        elseif ax==2 then p.Size=Vector3.new(sz,thick,sz)
        else p.Size=Vector3.new(sz,sz,thick) end
        p.BrickColor=blockPart.BrickColor; p.Transparency=0
        local hs=SNAP*0.5
        p.CFrame=CFrame.new(origin.X+rb(-hs,hs),origin.Y+rb(-hs,hs),origin.Z+rb(-hs,hs))
            *CFrame.Angles(math.random()*math.pi*2,math.random()*math.pi*2,math.random()*math.pi*2)

        local texId=texIds[math.random(1,#texIds)]
        for _,face in ipairs(Enum.NormalId:GetEnumItems()) do
            local t=Instance.new("Texture"); t.Texture=texId; t.Face=face
            local ts=rb(1.5,3.5); t.StudsPerTileU=ts; t.StudsPerTileV=ts
            t.OffsetStudsU=math.random(0,3); t.OffsetStudsV=math.random(0,3); t.Parent=p
        end
        p.Parent=workspace

        local bv=Instance.new("BodyVelocity")
        bv.Velocity=Vector3.new(rb(-1,1),rb(0.4,1.4),rb(-1,1)).Unit*rb(8,20)
        bv.MaxForce=Vector3.new(1e4,1e4,1e4); bv.P=1e4; bv.Parent=p

        local bav=Instance.new("BodyAngularVelocity")
        bav.AngularVelocity=Vector3.new(rb(-12,12),rb(-12,12),rb(-12,12))
        bav.MaxTorque=Vector3.new(1e5,1e5,1e5); bav.P=1e4; bav.Parent=p

        local lifetime=PARTICLE_LIFETIME*rb(0.7,1.3)
        task.spawn(function()
            task.wait(0.08)
            if bv.Parent then bv:Destroy() end
            local fadeTime=lifetime-0.08; local t0=tick(); local conn
            conn=RunService.Heartbeat:Connect(function()
                if not p or not p.Parent then conn:Disconnect() return end
                local alpha=math.clamp((tick()-t0)/fadeTime,0,1)
                p.Transparency=alpha
                if alpha>=1 then conn:Disconnect(); p:Destroy() end
            end)
        end)
        Debris:AddItem(p,lifetime+0.5)
    end
end

