local VM_BASE_CF = CFrame.new(1.45,-1.25,-2.2)
               * CFrame.Angles(math.rad(15),math.rad(-35),math.rad(20))

local vmSwingActive = false
local vmSwingOffset = CFrame.new()
local vmIdleTime    = 0
local vmBobOffset   = CFrame.new()

local function vmLerp(startCF, targetCF, dur)
    local t0=tick()
    while true do
        local a=math.min((tick()-t0)/dur,1)
        local e=a*a*(3-2*a)
        vmSwingOffset=startCF:Lerp(targetCF,e)
        if a>=1 then break end
        RunService.RenderStepped:Wait()
    end
end

local function vmPlaySwing()
    if vmSwingActive then return end
    vmSwingActive=true
    task.spawn(function()
        vmLerp(CFrame.new(),
            CFrame.new(0.35,0.1,0.3)*CFrame.Angles(math.rad(-25),math.rad(18),math.rad(-10)),0.08)
        vmLerp(vmSwingOffset,
            CFrame.new(0.55,-0.85,0.1)*CFrame.Angles(math.rad(55),math.rad(22),math.rad(5)),0.11)
        vmLerp(vmSwingOffset,CFrame.new(),0.16)
        vmSwingOffset=CFrame.new(); vmSwingActive=false
    end)
end

-- ══════════════════════════════════════════════════════════════
--  HANDLE  (FIX K)
--
--  The ONLY reliable way to hide a Tool Handle in first-person
--  on Roblox is to shrink it to a zero/tiny size. Transparency
--  and LocalTransparencyModifier are both reset by the engine
--  every frame for equipped tool handles.
--
--  Strategy:
--    FP + equipped  → handle.Size = Vector3.new(0,0,0)
--                     (invisible, no collision, no shadow)
--    TP / unequipped → handle.Size = HANDLE_REAL_SIZE
--
--  Enforced every RenderStepped frame so the engine can never win.
-- ══════════════════════════════════════════════════════════════
local HANDLE_REAL_SIZE = Vector3.new(1,1,1)
local HANDLE_ZERO_SIZE = Vector3.new(0,0,0)

local handle  -- assigned below after tool construction

local function updateHandleVisibility()
    if not handle or not handle.Parent then return end
    if isEquipped and isFirstPerson() then
        -- Shrink to zero — the only engine-proof hide for tool handles
        if handle.Size ~= HANDLE_ZERO_SIZE then
            handle.Size = HANDLE_ZERO_SIZE
        end
    else
        -- Restore real size in third-person or when unequipped
        if handle.Size ~= HANDLE_REAL_SIZE then
            handle.Size = HANDLE_REAL_SIZE
        end
    end
end

-- ══════════════════════════════════════════════════════════════
--  RENDERSTEP — single loop for VM + handle
-- ══════════════════════════════════════════════════════════════
_G.MCB_RenderConn = RunService.RenderStepped:Connect(function(dt)
    local fp = isFirstPerson()

    -- ViewportFrame visible only in FP + equipped
    vmGui.Enabled = isEquipped and fp

    -- FIX K: enforce handle size every frame
    updateHandleVisibility()

    if not (isEquipped and fp) then return end

    -- Mirror VF camera to main camera
    vfCam.CFrame      = camera.CFrame
    vfCam.FieldOfView = camera.FieldOfView

    -- Idle sway + walk bob
    local char     = player.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    local speed    = 0
    if rootPart then
        local vel=rootPart.Velocity
        speed=Vector2.new(vel.X,vel.Z).Magnitude
    end

    vmIdleTime = vmIdleTime + dt
    local swayX = math.sin(vmIdleTime*0.9)*0.025
    local swayY = math.sin(vmIdleTime*1.4)*0.012
    local idleCF = CFrame.new(swayX,swayY,0)

    local bobAmt = math.clamp(speed/16,0,1)
    local bobX   = math.sin(vmIdleTime*8.5)           * 0.09 * bobAmt
    local bobY   = math.abs(math.sin(vmIdleTime*8.5)) * 0.07 * bobAmt
    vmBobOffset  = CFrame.new(bobX,-bobY,0)

    vmPart.CFrame = camera.CFrame * VM_BASE_CF * idleCF * vmBobOffset * vmSwingOffset
end)

