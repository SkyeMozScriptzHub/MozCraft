-- ══════════════════════════════════════════════════════════════
--  RAYCAST
-- ══════════════════════════════════════════════════════════════
local rayParams=RaycastParams.new()
rayParams.FilterType=Enum.RaycastFilterType.Blacklist

local function buildFilter()
    local f={}
    if player.Character then f[1]=player.Character end
    rayParams.FilterDescendantsInstances=f
end

local function doRaycast()
    buildFilter()
    if S.lockMode then
        local char=player.Character
        local head=char and char:FindFirstChild("Head")
        local origin=head and head.Position or camera.CFrame.Position
        return workspace:Raycast(origin,camera.CFrame.LookVector*REACH,rayParams)
    else
        local mouse=player:GetMouse()
        local origin=camera.CFrame.Position
        local dir=(mouse.Hit.Position-origin).Unit*REACH
        return workspace:Raycast(origin,dir,rayParams)
    end
end

local function doRaycastFromScreen(screenPos)
    buildFilter()
    local ur=camera:ScreenPointToRay(screenPos.X,screenPos.Y)
    return workspace:Raycast(ur.Origin,ur.Direction*REACH,rayParams)
end

-- ══════════════════════════════════════════════════════════════
--  OVERLAP CHECK
-- ══════════════════════════════════════════════════════════════
local function overlapsPlayer(center)
    local char=player.Character; if not char then return false end
    local hx,hy,hz=SNAP*0.5,SNAP*0.5,SNAP*0.5
    for _,part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            local d=part.Position-center
            if math.abs(d.X)<part.Size.X*0.5+hx
            and math.abs(d.Y)<part.Size.Y*0.5+hy
            and math.abs(d.Z)<part.Size.Z*0.5+hz then return true end
        end
    end
    return false
end

-- ══════════════════════════════════════════════════════════════
--  CORE ACTIONS
-- ══════════════════════════════════════════════════════════════
local lastPlaced=0; local lastDeleted=0

local function spawnBlock(result)
    if not result then return end
    local center=calcPlacementCenter(result)
    if blockAtSnappedPos(center) then return end
    if overlapsPlayer(center) then return end

    task.spawn(playHandSwing); task.spawn(vmPlaySwing)

    local block=Instance.new("Part")
    block.Size=BLOCK_SIZE; block.Anchored=true; block.CanCollide=true
    block.Material=Enum.Material.SmoothPlastic; block.BrickColor=BrickColor.new("Bright green")
    block.CFrame=CFrame.new(center); block.Name="ClientBlock"; block.Parent=workspace
    addTextures(block)

    -- FIX M: tag every block with Type = "Grass"
    local sv = Instance.new("StringValue")
    sv.Name   = "Type"
    sv.Value  = "Grass"
    sv.Parent = block

    registerBlock(block)

    -- FIX L: fire-and-forget sound — one sound per place
    playRandom(PLACE_SOUND_IDS)
    setLastAction("Place")

    block.Size=BLOCK_SIZE*0.55
    local tw1=TweenService:Create(block,
        TweenInfo.new(0.13,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=BLOCK_SIZE*1.08})
    tw1:Play()
    tw1.Completed:Connect(function()
        if block and block.Parent then
            TweenService:Create(block,TweenInfo.new(0.07),{Size=BLOCK_SIZE}):Play()
        end
    end)
end

local function placeBlock(screenPos)
    if not isEquipped then return end
    if tick()-lastPlaced<PLACE_DEBOUNCE then return end
    lastPlaced=tick()
    spawnBlock(screenPos and doRaycastFromScreen(screenPos) or doRaycast())
end

local function deleteBlock()
    if not isEquipped then return end
    if tick()-lastDeleted<DELETE_DEBOUNCE then return end
    lastDeleted=tick()
    local result=doRaycast()
    if not result or not result.Instance then return end
    local target=result.Instance
    if target.Name~="ClientBlock" then return end
    task.spawn(playHandSwing); task.spawn(vmPlaySwing)

    -- FIX L: fire-and-forget sound — one sound per delete
    playRandom(DELETE_SOUND_IDS)
    unregisterBlock(target); setLastAction("Break")
    spawnBreakParticles(target)
    local tw=TweenService:Create(target,
        TweenInfo.new(0.06,Enum.EasingStyle.Quad,Enum.EasingDirection.In),
        {Size=BLOCK_SIZE*0.05,Transparency=0.8})
    tw:Play()
    tw.Completed:Connect(function() if target and target.Parent then target:Destroy() end end)
end

local function toggleLock()
    S.lockMode=not S.lockMode
    SV_LockState.Value=S.lockMode and "Locked" or "Unlocked"
    setLastAction("Lock"); setCrosshairVisible(S.lockMode)
    Events.LockChanged:Fire(S.lockMode)
end

-- ══════════════════════════════════════════════════════════════
--  EVENT LISTENERS
-- ══════════════════════════════════════════════════════════════
local eventConns={}
local function disconnectEventListeners()
    for _,c in ipairs(eventConns) do pcall(function() c:Disconnect() end) end
    eventConns={}
end
local function connectEventListeners()
    disconnectEventListeners()
    eventConns[1]=Events.Place.Event:Connect(function() placeBlock(nil) end)
    eventConns[2]=Events.Break.Event:Connect(deleteBlock)
    eventConns[3]=Events.Lock.Event:Connect(toggleLock)
end
connectEventListeners()

-- ══════════════════════════════════════════════════════════════
--  MOBILE TOUCH
-- ══════════════════════════════════════════════════════════════
if UserInputService.TouchEnabled then
    local activeTouches={}
    UserInputService.TouchStarted:Connect(function(inp,gp)
        if gp then return end; activeTouches[inp]=inp.Position
    end)
    UserInputService.TouchEnded:Connect(function(inp,gp)
        if gp then return end
        local sp=activeTouches[inp]; activeTouches[inp]=nil
        if not sp then return end
        if (inp.Position-sp).Magnitude<TAP_THRESHOLD then
            if not S.lockMode and isEquipped then placeBlock(inp.Position) end
        end
    end)
end

-- ══════════════════════════════════════════════════════════════
--  TOOL + HANDLE CONSTRUCTION
-- ══════════════════════════════════════════════════════════════
local tool=Instance.new("Tool")
tool.Name="Acacia Block"; tool.RequiresHandle=true
tool.TextureId=TOOL_TEXTURE; tool.Parent=player:WaitForChild("Backpack")

-- FIX K: handle declared here so updateHandleVisibility upvalue resolves
handle=Instance.new("Part")
handle.Name       = "Handle"
handle.Size       = HANDLE_REAL_SIZE   -- starts at full size
handle.Anchored   = false
handle.CanCollide = true
handle.Material   = Enum.Material.SmoothPlastic
handle.BrickColor = BrickColor.new("Bright green")
handle.Parent     = tool
addTextures(handle)

for _,tex in ipairs(handle:GetChildren()) do
    if tex:IsA("Texture") then
        tex.StudsPerTileU = 1
        tex.StudsPerTileV = 1
    end
end


tool.GripPos     = Vector3.new(0,0,0)
tool.GripForward = Vector3.new(0,0,-1)
tool.GripUp      = Vector3.new(0,1,0)
tool.GripRight   = Vector3.new(1,0,0)

-- ══════════════════════════════════════════════════════════════
--  EQUIPPED / UNEQUIPPED
-- ══════════════════════════════════════════════════════════════
tool.Equipped:Connect(function()
    isEquipped=true; SV_ToolState.Value="Equipped"
    connectEventListeners()
    -- Handle size managed by RenderStepped from this point on
end)

tool.Unequipped:Connect(function()
    isEquipped=false; SV_ToolState.Value="Unequipped"
    swingActive=false; vmSwingOffset=CFrame.new(); vmSwingActive=false
    vmGui.Enabled=false
    -- Immediately restore handle to full size on unequip
    if handle and handle.Parent then
        handle.Size = HANDLE_REAL_SIZE
    end
    if rightShoulder and defaultC0 then
        TweenService:Create(rightShoulder,
            TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),
            {C0=defaultC0}):Play()
    end
end)

-- ══════════════════════════════════════════════════════════════
--  RESPAWN
-- ══════════════════════════════════════════════════════════════
player.CharacterAdded:Connect(function()
    isEquipped=false; swingActive=false
    vmSwingOffset=CFrame.new(); vmSwingActive=false
    vmGui.Enabled=false
    camera=workspace.CurrentCamera
    setupArm(); connectEventListeners(); setCrosshairVisible(S.lockMode)
    -- Restore handle size on respawn
    if handle and handle.Parent then
        handle.Size = HANDLE_REAL_SIZE
    end
end)

-- ══════════════════════════════════════════════════════════════
--  PC KEYBINDS
-- ══════════════════════════════════════════════════════════════
local function bind(key,fn)
    ContextActionService:BindActionAtPriority(
        tostring(key),fn,false,Enum.ContextActionPriority.Default.Value,key)
end
bind(Enum.KeyCode.E,function(_,state) if state==Enum.UserInputState.Begin then placeBlock(nil) end end)
bind(Enum.KeyCode.R,function(_,state) if state==Enum.UserInputState.Begin then deleteBlock() end end)
bind(Enum.KeyCode.Q,function(_,state) if state~=Enum.UserInputState.Begin then return end toggleLock() end)
bind(Enum.KeyCode.Z,function(_,state)
    if state~=Enum.UserInputState.Begin then return end
    local char=player.Character
    if char and char:FindFirstChildOfClass("Tool") then
        local h=char:FindFirstChildOfClass("Humanoid"); if h then h:UnequipTools() end
    else
        if tool.Parent~=player.Backpack then tool.Parent=player.Backpack end
    end
end)

tool.Activated:Connect(function()
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then return end
    placeBlock(nil)
end)

UserInputService.InputBegan:Connect(function(inp,gp)
    if gp then return end
    if inp.UserInputType~=Enum.UserInputType.MouseButton2 then return end
    if tool.Parent~=player.Character then return end
    deleteBlock()
end)

-- ══════════════════════════════════════════════════════════════
--  CLEANUP
-- ══════════════════════════════════════════════════════════════
player.AncestryChanged:Connect(function()
    if player:IsDescendantOf(game) then return end
    pcall(function()
        disconnectEventListeners()
        if _G.MCB_RenderConn then _G.MCB_RenderConn:Disconnect(); _G.MCB_RenderConn=nil end
        if _G.MCB_VM_Gui and _G.MCB_VM_Gui.Parent then _G.MCB_VM_Gui:Destroy() end
        for _,k in ipairs({Enum.KeyCode.E,Enum.KeyCode.R,Enum.KeyCode.Q,Enum.KeyCode.Z}) do
            ContextActionService:UnbindAction(tostring(k))
        end
    end)
end)
