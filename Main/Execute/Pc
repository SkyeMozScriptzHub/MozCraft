local function addTextures(part)
    for face, id in pairs(FACE_TEXTURES) do
        local t = Instance.new("Texture")
        t.Texture=id; t.Face=face; t.StudsPerTileU=4; t.StudsPerTileV=4; t.Parent=part
    end
end

-- ══════════════════════════════════════════════════════════════
--  SOUNDS  (FIX L)
--
--  playRandom() clones the chosen Sound into PlayerGui, plays it,
--  then Debris destroys it after 3 s. Because every call gets its
--  own fresh Sound instance, any number of sounds can play
--  simultaneously with no waiting. One call fires per place/delete.
-- ══════════════════════════════════════════════════════════════
local function playRandom(ids)
    local id  = ids[math.random(1, #ids)]
    local snd = Instance.new("Sound")
    snd.SoundId = id
    snd.Volume  = 1
    snd.Parent  = PlayerGui   -- needs a parent to play
    snd:Play()
    Debris:AddItem(snd, 3)    -- auto-cleaned up after 3 s
end

-- ══════════════════════════════════════════════════════════════
--  FIRST-PERSON DETECTION
-- ══════════════════════════════════════════════════════════════
local FP_THRESHOLD = 1.0
local function isFirstPerson()
    local char = player.Character
    if not char then return false end
    local head = char:FindFirstChild("Head")
    if not head then return false end
    if camera.CameraType == Enum.CameraType.Scriptable then return false end
    return (camera.CFrame.Position - head.Position).Magnitude < FP_THRESHOLD
end

